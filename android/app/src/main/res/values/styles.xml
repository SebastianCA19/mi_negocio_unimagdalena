<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
        LaunchTheme: visible mientras Flutter inicializa.
        Usa Theme.Light para que el windowBackground azul aplique
        correctamente sin fondo negro.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">#1F4E79</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <!-- 
        NormalTheme: se aplica después de que Flutter toma el control
        (referenciado en el meta-data "NormalTheme" del AndroidManifest).
        Fondo blanco para que Flutter pinte su propio UI sin artefactos.
    -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">#1F4E79</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
